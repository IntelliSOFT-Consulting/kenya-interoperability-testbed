<?xml version="1.0" encoding="UTF-8"?>
<testcase id="testCaseCarePlanValidation" xmlns="http://www.gitb.com/tdl/v1/" xmlns:gitb="http://www.gitb.com/core/v1/">
    <metadata>
        <gitb:name>CarePlan (KPS)</gitb:name>
        <gitb:version>1.0</gitb:version>
        <gitb:description>
        Validation of a CarePlan resource against the KPS Implementation Guide. This test ensures that the proposed clinical goals and planned activities for a patient’s health management are structured according to multi-disciplinary care standards.
        </gitb:description>
    </metadata>
    <actors>
        <gitb:actor id="ClientSystem" name="Client System" role="SUT"/>
        <gitb:actor id="HAPIServer" name="HAPI Server"/>
    </actors>
    <steps>
        <assign to="httpHeaders{Content-Type}">"application/json"</assign>

        <receive id="receivePatientData" desc="Receive patient CarePlan payload" handler="HttpMessagingV2">
            <input name="uriExtension">"/CarePlan"</input>
            <input name="method">"POST"</input>
            <input name="status">200</input>
            <input name="headers">$httpHeaders</input>
        </receive>

        <send id="forwardToHAPI" desc="Forward CarePlan payload to HAPI server" handler="HttpMessagingV2">
            <input name="uri">"http://hapi-fhir:8080/fhir/CarePlan"</input>
            <input name="method">"POST"</input>
            <input name="body">$receivePatientData{request}{body}</input>
            <input name="headers">$httpHeaders</input>
        </send>

        <verify handler="StringValidator" desc="Validate server response status">
            <input name="actual">$forwardToHAPI{response}{status}</input>
            <input name="expected">"201"</input>
            <input name="failureMessage">"The server response status was not 201."</input>
        </verify>

        <assign to="hapiResponse">$forwardToHAPI{response}{body}</assign>
    </steps>

    <output>
        <success>
            <default>$hapiResponse</default>
        </success>
        <failure>
            <default>$hapiResponse</default>
        </failure>
    </output>
</testcase>