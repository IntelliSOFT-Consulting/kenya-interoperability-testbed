<?xml version="1.0" encoding="UTF-8"?>
<testsuite id="patientValidationSuite" xmlns="http://www.gitb.com/tdl/v1/" xmlns:gitb="http://www.gitb.com/core/v1/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <metadata>
        <gitb:name>SIL (IPS) Payload Validation Suite</gitb:name>
        <gitb:description>Test suite to validate (SIL) IPS payloads by forwarding them to a HAPI server.</gitb:description>
        <gitb:version>1.0</gitb:version>
    </metadata>
    <actors>
        <gitb:actor id="ClientSystem">
            <gitb:name>Client System</gitb:name>
            <gitb:desc>The system that sends patient payloads for validation.</gitb:desc>
        </gitb:actor>
        <gitb:actor id="HAPIServer">
            <gitb:name>HAPI Server</gitb:name>
            <gitb:desc>The server that validates the patient payloads.</gitb:desc>
        </gitb:actor>
    </actors>
    <testcase id="testCasePatientValidation"/>
    <testcase id="testCaseConditionValidation"/>
    <testcase id="testCaseAllergyIntoleranceValidation"/>
    <testcase id="testCaseImmunizationValidation"/>
    <testcase id="testCaseCarePlanValidation"/>
    <testcase id="testCaseProcedureValidation"/>
    <testcase id="testCaseMedicationValidation"/>
    <testcase id="testCaseBundleValidation"/> 
</testsuite>