<?xml version="1.0" encoding="UTF-8"?>
<testcase id="testCaseAllergyIntoleranceValidation" xmlns="http://www.gitb.com/tdl/v1/" xmlns:gitb="http://www.gitb.com/core/v1/">
    <metadata>
        <gitb:name>Allergy Intolerance (KPS)</gitb:name>
        <gitb:version>1.0</gitb:version>
        <gitb:description>Validation of an AllergyIntolerance resource against the KPS Implementation Guide. 
        This test ensures the accurate recording of a patient’s risk for adverse reactions to substances, verifying that criticality and clinical status meet national safety reporting requirements.</gitb:description>
    </metadata>

    <actors>
        <gitb:actor id="ClientSystem" name="Client System" role="SUT"/>
        <gitb:actor id="HAPIServer" name="HAPI Server"/>
    </actors>

    <steps>
        <assign to="httpHeaders{Content-Type}">"application/json"</assign>

        <receive id="receivePatientData" desc="Receive patient allergy Intolerance payload" handler="HttpMessagingV2">
            <input name="uriExtension">"/AllergyIntolerance"</input>
            <input name="method">"POST"</input>
            <input name="status">200</input>
            <input name="headers">$httpHeaders</input>
        </receive>

        <send id="forwardToHAPI" desc="Forward to HAPI server" handler="HttpMessagingV2">
            <input name="uri">"http://hapi.fhir.org/baseR4/AllergyIntolerance"</input>
            <input name="method">"POST"</input>
            <input name="body">$receivePatientData{request}{body}</input>
            <input name="headers">$httpHeaders</input>
        </send>

        <verify handler="StringValidator" desc="Validate server response status">
            <input name="actual">$forwardToHAPI{response}{status}</input>
            <input name="expected">"201"</input>
        </verify>

        <assign to="hapiResponse">$forwardToHAPI{response}{body}</assign>
    </steps>

    <output>
        <success>
            <default>$hapiResponse</default>
        </success>
        <failure>
            <default>$hapiResponse</default>
        </failure>
    </output>
</testcase>