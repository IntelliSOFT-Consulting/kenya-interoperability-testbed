<?xml version="1.0" encoding="UTF-8"?>
<testcase id="testCaseMedicationValidation" xmlns="http://www.gitb.com/tdl/v1/" xmlns:gitb="http://www.gitb.com/core/v1/">
    <metadata>
        <gitb:name>Medication (KPS)</gitb:name>
        <gitb:version>1.0</gitb:version>
        <gitb:description>Validation of a Medication resource against the KPS Implementation Guide. This test verifies that medicinal product details, including coding systems (e.g., NHDD codes, ICD-11 codes), are correctly structured to support pharmacy and supply chain interoperability.</gitb:description>
    </metadata>
    <actors>
        <gitb:actor id="ClientSystem" name="Client System" role="SUT"/>
        <gitb:actor id="HAPIServer" name="HAPI Server"/>
    </actors>
    <steps>
        <!-- Define HTTP headers -->
        <assign to="httpHeaders{Content-Type}">"application/json"</assign>

        <!-- Receive Medication payload -->
        <receive id="receivePatientData" desc="Receive patient medication payload" handler="HttpMessagingV2">
            <input name="uriExtension">"/Medication"</input>
            <input name="method">"POST"</input>
            <input name="status">200</input>
            <input name="body">"ACK-1234567890"</input>
            <input name="headers">$httpHeaders</input>
        </receive>

        <!-- Forward payload to HAPI server -->
        <send id="forwardToHAPI" desc="Forward medication payload to HAPI server" handler="HttpMessagingV2">
            <input name="uri">"http://hapi.fhir.org/baseR4/Medication"</input>
            <input name="method">"POST"</input>
            <input name="body">$receivePatientData{request}{body}</input>
            <input name="headers">$httpHeaders</input>
        </send>

        <!-- Validate the server response status code -->
        <verify handler="StringValidator" desc="Validate server response status">
            <input name="actual">$forwardToHAPI{response}{status}</input>
            <input name="expected">"201"</input>
            <input name="failureMessage">"The server response status was not 201."</input>
        </verify>

        <!-- Additional validation checks can be added here -->
    </steps>

    <output>
        <success>
            <default>"Patient medication payload validation succeeded based on server response."</default>
        </success>
        <failure>
            <default>"Patient medication payload validation failed. Check the server response for details."</default>
        </failure>
    </output>
</testcase>
